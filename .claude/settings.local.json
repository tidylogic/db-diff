{
  "permissions": {
    "allow": [
      "Bash(go get:*)",
      "Read(//mnt/c/Github/personal/**)",
      "Bash(go build:*)",
      "Bash(go mod:*)",
      "Bash(./db-diff.exe --help)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "if": "Edit|Write(internal/**/*.go)|Write|Edit(cmd/**/*.go)",
            "prompt": "코드 파일(.go)이 변경되었습니다. README 파일(README.md, README-ko.md)도 업데이트가 필요한지 확인하세요. 새로운 기능이 추가되거나 동작이 변경되었다면 README를 함께 업데이트해주세요.",
            "statusMessage": "README 업데이트 필요성 확인 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "if": "Bash(git commit:*)",
            "prompt": "git commit을 실행하려고 합니다. 코드 변경사항이 있다면 README.md와 README-ko.md도 함께 업데이트되었는지 확인해주세요. 필요한 경우 README 업데이트 후 커밋하세요.",
            "statusMessage": "README 업데이트 상태 확인 중..."
          }
        ]
      }
    ]
  }
}
